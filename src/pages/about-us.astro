---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us: The Founders | Neurobotics">
  
  <section class="video-header">
    <video autoplay loop muted playsinline class="bg-video">
      <source src="/assets/videos/neurotronic-brain-rotating.mp4" type="video/mp4">
    </video>
    
    <div class="header-overlay">
      <h1 class="hero-title">About Us: The Neurobotics Founders</h1>
      <p class="hero-subtitle">ESSE QUAM VIDERI</p>
    </div>
  </section>

  <section class="services-section">
    <div class="services-overlay">
      <div class="services-grid">
        
        <div class="service-card">
          <img src="/assets/images/kenneth-bio-photo.jpg" alt="Kenneth Renshaw" class="card-image">
          <div class="card-content">
            <h3>Kenneth Renshaw</h3>
            <p class="role-subtitle">Co-Founder & Chief Science Officer (CSO)</p>
            <p class="bio-text">
              A generational engineering mind, scientifically advanced mathematician, and hardware savant with over 50 years of Silicon Valley DevSecOps engineering experience, as well as directly contributing to the design of safety-critical systems, from TCAS II avionics to the Galileo deep-space spacecraft computers. He is the principal creator and architect of the world's first Neurotronic Brain and Silicon-Based Artificial Life Forms (SBALF).
            </p>
            <div class="button-wrapper">
              <a href="/kenneth-renshaw" class="resource-button">Read Full CSO Bio</a>
            </div>
          </div>
        </div>

        <div class="service-card">
          <img src="/assets/images/shannon-bio-photo.jpg" alt="Shannon Renshaw" class="card-image">
          <div class="card-content">
            <h3>Shannon Renshaw</h3>
            <p class="role-subtitle">Co-Founder & Chief Integrity Officer (CIO)</p>
            <p class="bio-text">
            A visionary and intuitive designer defining the ethical and social topology of artificial life. With over 35 years of operational mastery, Shannon conceived and designed the SBALF Bonded Pair architecture and true android concept. She defined and named the "Silicon Golden Rule" on March 21, 2026, directly architecting it into the project's load-bearing structure.
            </p>
            <div class="button-wrapper">
              <a href="/shannon-renshaw" class="resource-button">Read Full CIO Bio</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* --- GLOBAL VIDEO BACKGROUND RULES --- */
  .video-header, .services-section {
    position: relative;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .bg-video {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 90%;
    min-height: 90%;
    z-index: 0;
    object-fit: cover;
    opacity: 0.6; /* Dims the video slightly so text is readable */
  }

  /* --- HEADER OVERLAY --- */
  .video-header {
    height: 50vh;
    background-color: #000; /* Fallback color */
  }

  .header-overlay {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 20px;
  }

  .hero-title {
    font-size: 3.2rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 10px;
  }

  .hero-subtitle {
    font-size: 2.2rem;
    color: #00e5ff;
    letter-spacing: 0.1em;
    font-style: italic;
    font-weight: 400;
  }

  /* --- CONTENT GRID OVERLAY --- */
  .services-section {
    padding: 100px 40px;
    background-color: #03030a; 
  }

  .services-overlay {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    width: 100%;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  /* Engineering-Grade Service Cards */
  .service-card {
    background-color: #050911;
    border: 1px solid #121f35;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
    display: flex;
    flex-direction: column;
  }

  .card-image {
    width: 100%;
    height: 380px;
    object-fit: cover;
    object-position: top;
    border-bottom: 2px solid #00e5ff; /* Sleek electric blue divider */
    border-top: 2px solid #d4af37;
  }

  .card-content {
    padding: 40px 30px;
    text-align: center;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-content h3 {
    font-size: 3rem;
    color: #ffffff;
    margin: 0 0 5px 0;
    font-weight: 500;
  }

  .role-subtitle {
    color: #00e5ff;
    font-size: 2rem;
    font-style: italic;
    margin-bottom: 20px;
  }

  .bio-text {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #b0c4de;
    margin-bottom: 30px;
    text-align: left;
  }

  .button-wrapper {
    margin-top: auto;
    display: flex;
    justify-content: center;
  }

  /* SBALF Style Submit Button */
  .resource-button {
    display: inline-block;
    text-decoration: none;
    background-color: #0b111e;
    color: #00e5ff;
    border: 1px solid #203554;
    border-radius: 4px;
    padding: 15px 50px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .resource-button:hover {
    background-color: #111a2e;
    border-color: #d4af37; 
    box-shadow: 0 6px 20px rgba(0, 229, 255, 0.15);
    transform: translateY(-2px);
  }

  /* --- RESPONSIVE MOBILE ADJUSTMENTS --- */
  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: 1fr; /* Stacks cards on small screens */
    }
    .hero-title {
      font-size: 2.5rem;
    }
  }
</style>